<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Urgence Lilloise Semi FivePD</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Montserrat', 'Segoe UI', sans-serif;
    }

    body {
      background-color: #0a0a0c;
      color: #ffffff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;

      /* BANNIÈRE */
      background-image: linear-gradient(rgba(10, 10, 12, 0.4), rgba(10, 10, 12, 0.4)),
                        url('https://media.discordapp.net/attachments/1525164832087736441/1529277636134568087/image.png?ex=6a615a49&is=6a6008c9&hm=c427cd5b7d609a5a84fc47b101b0d27ca3d608c56cf720fd938474acd365eaadd&=&format=webp&quality=lossless');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;
    }

    /* HEADER */
    header {
      padding: 25px 60px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 10;
      background: rgba(10, 10, 12, 0.5);
      backdrop-filter: blur(8px);
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 900;
      color: #ffffff;
      text-decoration: none;
      letter-spacing: 1px;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo img {
      height: 45px;
      width: auto;
    }

    .logo span {
      color: #e52d48;
    }

    nav {
      display: flex;
      gap: 30px;
      align-items: center;
    }

    nav a {
      color: #a0a0a0;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: color 0.3s;
    }

    nav a:hover, nav a.active {
      color: #ffffff;
    }

    .btn-discord {
      background-color: #5865F2;
      color: #ffffff;
      padding: 10px 20px;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: transform 0.2s, background-color 0.2s;
    }

    .btn-discord:hover {
      background-color: #4752C4;
      transform: translateY(-2px);
    }

    /* HERO SECTION */
    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 60px 10%;
      z-index: 2;
    }

    .sub-title {
      color: #e52d48;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .sub-title::before {
      content: '— ';
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    p.description {
      color: #a0a0a0;
      font-size: 1.1rem;
      max-width: 600px;
      line-height: 1.6;
      margin-bottom: 35px;
    }

    .cta-container {
      display: flex;
      gap: 15px;
      align-items: center;
    }

    .btn-primary {
      background-color: #e52d48;
      color: #ffffff;
      padding: 14px 28px;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 800;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: background-color 0.2s, transform 0.2s;
    }

    .btn-primary:hover {
      background-color: #c02138;
      transform: translateY(-2px);
    }

    .btn-secondary {
      background-color: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #ffffff;
      padding: 14px 28px;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: background-color 0.2s, border-color 0.2s;
    }

    .btn-secondary:hover {
      background-color: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.3);
    }

    /* SECTION CARROUSEL DES MÉTIERS */
    .jobs-section {
      padding: 40px 0 60px 0;
      overflow: hidden;
      position: relative;
      background: rgba(10, 10, 12, 0.6);
      backdrop-filter: blur(5px);
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .jobs-section h2 {
      font-size: 1.6rem;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 25px;
      color: #ffffff;
      padding-left: 10%;
      letter-spacing: 1px;
    }

    .carousel-track {
      display: flex;
      gap: 20px;
      width: max-content;
      animation: scrollJobs 30s linear infinite;
    }

    .carousel-track:hover {
      animation-play-state: paused;
    }

    @keyframes scrollJobs {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(calc(-50% - 10px));
      }
    }

    .job-card {
      width: 260px;
      height: 360px;
      border-radius: 12px;
      background-color: #0a0a0c;
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: transform 0.3s ease, border-color 0.3s ease;
    }

    .job-card:hover {
      transform: translateY(-8px);
      border-color: #e52d48;
    }

    .job-overlay {
      position: absolute;
      inset: 0;
      padding: 20px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }

    .job-badge {
      align-self: flex-start;
      background: rgba(229, 45, 72, 0.2);
      color: #ff4d6d;
      border: 1px solid rgba(229, 45, 72, 0.4);
      font-size: 0.65rem;
      font-weight: 800;
      padding: 4px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .job-badge.police {
      background: rgba(45, 125, 229, 0.2);
      color: #4da6ff;
      border-color: rgba(45, 125, 229, 0.4);
    }

    .job-badge.samu {
      background: rgba(229, 219, 45, 0.2);
      color: #ffe64d;
      border-color: rgba(229, 219, 45, 0.4);
    }

    .job-badge.prot {
      background: rgba(229, 116, 45, 0.2);
      color: #ff9d4d;
      border-color: rgba(229, 116, 45, 0.4);
    }

    .job-card h3 {
      font-size: 1.2rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 6px;
    }

    .job-card p {
      font-size: 0.8rem;
      color: #a0a0a0;
      line-height: 1.3;
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <a href="/" class="logo">
      <img src="https://media.discordapp.net/attachments/1490687935509430293/1529274485063028807/logo.png?ex=6a615759&is=6a6005d9&hm=097142531e6bc6a87627bc785c57bfbceae7245f06f4d118411ee0c3c3c9bf23&=&format=webp&quality=lossless" alt="Logo Urgence Lilloise">
      Urgence Lilloise <span>Semi FivePD</span>
    </a>
    <nav>
      <a href="/" class="active">Accueil</a>
      <a href="/boutique">Boutique</a>
      <a href="https://discord.gg/votre-lien" target="_blank" class="btn-discord">
        <i class="fa-brands fa-discord"></i> Discord
      </a>
    </nav>
  </header>

  <!-- HERO SECTION -->
  <main class="hero">
    <div class="sub-title">Serveur Roleplay Français</div>
    <h1>Urgence Lilloise<br>Semi FivePD</h1>
    <p class="description">
      Rejoins une expérience Roleplay unique axée sur les services d'urgence, la gendarmerie et la vie civile dans la métropole lilloise.
    </p>
    <div class="cta-container">
      <a href="fivem://connect/votre-ip" class="btn-primary">
        <i class="fa-solid fa-play"></i> Rejoindre le serveur
      </a>
      <a href="/reglement" class="btn-secondary">
        <i class="fa-solid fa-book"></i> Lire le règlement
      </a>
    </div>
  </main>

  <!-- SECTION CARROUSEL MÉTIERS -->
  <section class="jobs-section">
    <h2>Métiers & Factions</h2>

    <div class="carousel-track">
      
      <!-- SÉRIE 1 -->
      <div class="job-card">
